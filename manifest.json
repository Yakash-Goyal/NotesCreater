{
  "manifest_version": 3,
  "name": "YouTube Clean Screenshot",
  "version": "1.0",
  "description": "Capture clean YouTube lecture screenshots without UI clutter.",
  "permissions": ["downloads", "activeTab"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}